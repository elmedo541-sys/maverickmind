generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String

  @@map("admin")
}

model Category {
  id           Int       @id @default(autoincrement())
  categoryName String    @unique @map("category_name")
  products     Product[]

  @@map("categories")
}

model Brand {
  id        Int       @id @default(autoincrement())
  brandName String    @unique @map("brand_name")
  products  Product[]

  @@map("brands")
}

model Product {
  id          Int       @id @default(autoincrement())
  productName String    @map("product_name")
  modelNumber String?   @map("model_number")
  categoryId  Int?      @map("category_id")
  category    Category? @relation(fields: [categoryId], references: [id])
  brandId     Int?      @map("brand_id")
  brand       Brand?    @relation(fields: [brandId], references: [id])
  price       Decimal   @db.Decimal(10, 2)
  quantity    Int       @default(0)
description String    @db.Text
  images      String[]  @default([])
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("products")
}

model Service {
  id          Int      @id @default(autoincrement())
  serviceName String   @map("service_name")
  description String   @db.Text
  image       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("services")
}

model Slide {
  id        Int      @id @default(autoincrement())
  title     String
  subtitle  String?
  image     String
  linkUrl   String?  @map("link_url")
  linkLabel String?  @map("link_label")
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("slides")
}

model Inquiry {
  id               Int      @id @default(autoincrement())
  name             String
  email            String
  message          String   @db.Text
  preferredContact String   @default("Email") @map("preferred_contact")
  contactDetail    String?  @map("contact_detail")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("inquiries")
}
